<Page x:Class="WpfApp1.Pages.ReadingListsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Моя коллекция" Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="20" Margin="0,0,0,15">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#2C3E50" Offset="0"/>
                    <GradientStop Color="#3498DB" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock Text="📚 Моя коллекция" FontSize="22" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Управляйте списком книг, которые читаете или планируете прочитать" FontSize="12" Foreground="#BDC3C7" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="📌 Фильтр по статусу:" VerticalAlignment="Center" Foreground="#555" FontWeight="SemiBold" FontSize="13" Margin="0,0,15,0"/>

                <ComboBox x:Name="StatusComboBox" Grid.Column="1" Width="200" Height="35" 
                          Background="White" BorderBrush="#D5D8DC" BorderThickness="1"
                          SelectionChanged="StatusComboBox_SelectionChanged" FontSize="13" Padding="8,0">
                    <ComboBoxItem Content="📖 Все книги" IsSelected="True"/>
                    <ComboBoxItem Content="📖 В процессе чтения"/>
                    <ComboBoxItem Content="⏳ Ожидают прочтения"/>
                    <ComboBoxItem Content="✅ Прочитано"/>
                    <ComboBoxItem Content="❌ Отложено"/>
                </ComboBox>

                <TextBlock x:Name="CountTextBlock" Grid.Column="2" Text="Всего: 0 книг" 
                           VerticalAlignment="Center" HorizontalAlignment="Right" 
                           Foreground="#7F8C8D" FontSize="12"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ListView x:Name="ListsListView" Background="Transparent" BorderThickness="0">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E5E5E5" BorderThickness="0,0,0,1" Padding="15,12" Margin="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Book.Title}" FontWeight="Bold" FontSize="15" 
                                                   Foreground="#2C3E50" Margin="0,0,0,5"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📝 Автор: " Foreground="#7F8C8D" FontSize="12"/>
                                            <TextBlock Text="{Binding Book.User.DisplayName}" Foreground="#555" FontSize="12"/>
                                            <TextBlock Text=" · " Foreground="#BDC3C7" FontSize="12"/>
                                            <TextBlock Text="⭐ " Foreground="#F39C12" FontSize="11"/>
                                            <TextBlock Text="{Binding Book.Rating}" Foreground="#555" FontSize="11"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Grid.Column="1" Content="✅ В прочитанное" Click="MoveToRead_Click" Tag="{Binding ReadingListId}" 
                                            Margin="10,0" Padding="15,8" Background="#27AE60" Foreground="White" 
                                            BorderThickness="0" Cursor="Hand" FontSize="12"/>

                                    <Button Grid.Column="2" Content="🗑 Удалить" Click="Delete_Click" Tag="{Binding ReadingListId}" 
                                            Margin="5,0" Padding="15,8" Background="#E74C3C" Foreground="White" 
                                            BorderThickness="0" Cursor="Hand" FontSize="12"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </ScrollViewer>
        </Border>

        <Border x:Name="EmptyStateBorder" Grid.Row="2" Background="White" 
                Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" Height="200">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="📭" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <TextBlock Text="У вас пока нет книг в коллекции" FontSize="16" Foreground="#7F8C8D" HorizontalAlignment="Center"/>
                <TextBlock Text="Добавьте книги из каталога" FontSize="13" Foreground="#BDC3C7" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>