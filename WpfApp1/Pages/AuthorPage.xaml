<Page x:Class="WpfApp1.Pages.AuthorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Панель Литератора" Background="#F0F2F5">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="12" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="SpaceBetween">
                <TextBlock Text="Мой Творческий Портфель" FontSize="20" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                <Button Content="➕ Выложить Новинку" Click="AddBookButton_Click" Padding="15,8" 
                        Background="#E67E22" Foreground="White" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" BorderThickness="1" Background="#F8F9FA">
            <TabItem Header="📖 В Доступе">
                <DataGrid x:Name="ActiveBookGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                          AlternatingRowBackground="#F0F0F0" RowHeight="40" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Наименование" Binding="{Binding Title}" Width="220"/>
                        <DataGridTextColumn Header="Раздел" Binding="{Binding Genres.Name}" Width="120"/>
                        <DataGridTextColumn Header="Баллы" Binding="{Binding Rating}" Width="70"/>
                        <DataGridTemplateColumn Header="Операции">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✏ Правка" Click="EditBook_Click" Tag="{Binding BookId}" 
                                            Background="#3498DB" Foreground="White" Padding="8,4" BorderThickness="0" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="⛔ В Ограничении">
                <DataGrid x:Name="FrozenBookGrid" AutoGenerateColumns="False" IsReadOnly="True" 
                          Background="#FFF5F5F5" AlternatingRowBackground="#FFEBEB" RowHeight="40">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Наименование" Binding="{Binding Title}" Width="220"/>
                        <DataGridTextColumn Header="Причина Блокировки" Binding="{Binding FreezeReason}" Width="*"/>
                        <DataGridTemplateColumn Header="Операции">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="⚖ Подать Апелляцию" Click="Appeal_Click" Tag="{Binding BookId}" 
                                            Background="#E67E22" Foreground="White" Padding="8,4" BorderThickness="0" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>