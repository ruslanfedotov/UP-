<Page x:Class="WpfApp1.Pages.CatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Библиотека произведений" Background="#F0F2F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="20" Margin="0,0,0,15">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#2C3E50" Offset="0"/>
                    <GradientStop Color="#3498DB" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <StackPanel>
                <TextBlock Text="📚 Библиотека произведений" FontSize="22" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text="Откройте для себя тысячи книг от талантливых авторов" FontSize="12" Foreground="#BDC3C7" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="🔍" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <TextBox x:Name="SearchTextBox" Grid.Column="1" Height="35" Padding="10,0" 
                         BorderBrush="#D5D8DC" BorderThickness="1" FontSize="13"
                         Tag="Поиск по названию..."/>

                <TextBlock Grid.Column="2" Text="📂 Жанр:" VerticalAlignment="Center" Margin="15,0,8,0" Foreground="#555" FontSize="12"/>
                <ComboBox x:Name="GenreFilterCombo" Grid.Column="3" Width="140" Height="35" 
                          Background="White" BorderBrush="#D5D8DC" BorderThickness="1"
                          DisplayMemberPath="Name" SelectionChanged="FilterChanged" Padding="8,0"/>

                <TextBlock Grid.Column="4" Text="📊 Сортировка:" VerticalAlignment="Center" Margin="15,0,8,0" Foreground="#555" FontSize="12"/>
                <ComboBox x:Name="SortCombo" Grid.Column="5" Width="140" Height="35" 
                          Background="White" BorderBrush="#D5D8DC" BorderThickness="1"
                          SelectionChanged="FilterChanged" Padding="8,0">
                    <ComboBoxItem Content="📖 По алфавиту" IsSelected="True"/>
                    <ComboBoxItem Content="⭐ По популярности"/>
                    <ComboBoxItem Content="🆕 Сначала новые"/>
                </ComboBox>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ListView x:Name="BookListView" 
                          MouseDoubleClick="BookListView_MouseDoubleClick"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          Background="Transparent" BorderThickness="0">
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E5E5E5" BorderThickness="1" Margin="10" Padding="12" 
                                    Width="180" Height="240" Background="White" Cursor="Hand">
                                <StackPanel>
                                    <Border Background="#F8F9FA" Height="130" Margin="0,0,0,10">
                                        <Image Source="{Binding CoverPath}" Height="120" Width="100" 
                                               Stretch="Uniform" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" TextWrapping="Wrap" 
                                               FontSize="13" Foreground="#2C3E50" MaxHeight="40"/>
                                    <TextBlock Text="{Binding User.DisplayName}" Foreground="#7F8C8D" 
                                               FontSize="11" Margin="0,5,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock Text="⭐ " Foreground="#F39C12" FontSize="11"/>
                                        <TextBlock Text="{Binding Rating}" Foreground="#555" FontSize="11"/>
                                        <TextBlock Text=" · " Foreground="#BDC3C7" FontSize="11"/>
                                        <TextBlock Text="💬 " Foreground="#3498DB" FontSize="11"/>
                                        <TextBlock Text="{Binding Reviews.Count}" Foreground="#555" FontSize="11"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>