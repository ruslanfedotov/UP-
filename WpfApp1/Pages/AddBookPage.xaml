<Page x:Class="WpfApp1.Pages.AddBookPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Добавление книги" Background="#F9F9F9">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30" MaxWidth="600" HorizontalAlignment="Stretch">

            <Border Background="White" Padding="25" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>

                    <TextBlock Text="📖 Добавление новой книги" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#2C3E50"/>

                    <TextBlock Text="Название книги" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
                    <TextBox x:Name="TitleBox" Margin="0,0,0,15" Padding="10" BorderBrush="#CCC" BorderThickness="1" FontSize="14"/>

                    <TextBlock Text="Описание" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
                    <TextBox x:Name="DescBox" Height="100" TextWrapping="Wrap" Margin="0,0,0,15" Padding="10" BorderBrush="#CCC" BorderThickness="1" FontSize="14" VerticalScrollBarVisibility="Auto"/>

                    <TextBlock Text="Текст книги" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
                    <TextBox x:Name="ContentBox" Height="250" TextWrapping="Wrap" Margin="0,0,0,20" Padding="10" BorderBrush="#CCC" BorderThickness="1" FontSize="14" VerticalScrollBarVisibility="Auto"/>

                    <Button Content="✍️ Опубликовать книгу" Click="SaveBook_Click" Height="45" Background="#2C3E50" Foreground="White" BorderBrush="#2C3E50" BorderThickness="1" FontSize="14" FontWeight="SemiBold" Cursor="Hand"/>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>