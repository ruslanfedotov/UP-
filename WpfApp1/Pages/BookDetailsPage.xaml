<Page x:Class="WpfApp1.Pages.BookDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="📖 Детали книги" Background="#F0F2F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="White" Padding="20" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock x:Name="TitleTxt" FontSize="26" FontWeight="Bold" Foreground="#2C3E50" TextWrapping="Wrap"/>
                    <TextBlock x:Name="AuthorTxt" FontSize="14" Foreground="#7F8C8D" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" Background="White" Padding="20" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="📄 Описание" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                    <TextBlock x:Name="DescTxt" TextWrapping="Wrap" Foreground="#555" FontSize="14"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="2" Background="White" Padding="20" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="📚 Текст книги" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10"/>
                    <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="ContentTxt" TextWrapping="Wrap" Foreground="#444" FontSize="14" LineHeight="1.4"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Background="White" Padding="20" Margin="0,0,0,15">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="📌 Добавить в список:" FontSize="14" FontWeight="SemiBold" Foreground="#2C3E50" VerticalAlignment="Center" Margin="0,0,15,0"/>

                    <ComboBox x:Name="StatusSelectCombo" Grid.Column="1" Width="150" VerticalAlignment="Center" SelectedIndex="0" Padding="8">
                        <ComboBoxItem Content="📖 Хочу прочитать"/>
                        <ComboBoxItem Content="🔄 Читаю"/>
                        <ComboBoxItem Content="✅ Прочитано"/>
                        <ComboBoxItem Content="⏸ Отложено"/>
                    </ComboBox>

                    <Button Content="➕ Сохранить" Click="AddToList_Click" Grid.Column="2" 
                            Background="#27AE60" Foreground="White" BorderThickness="0"
                            Padding="20,8" Cursor="Hand" FontSize="13" FontWeight="SemiBold" Margin="15,0,0,0"/>
                </Grid>
            </Border>

            <Border Grid.Row="4" Background="White" Padding="20">
                <StackPanel>
                    <TextBlock Text="💬 Отзывы читателей" FontSize="16" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,15"/>

                    <Border Background="#F8F9FA" Padding="15" Margin="0,0,0,20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="ReviewTextBox" Grid.Row="0" Grid.ColumnSpan="2" TextWrapping="Wrap" Height="80" 
                                     Padding="10" FontSize="13" BorderBrush="#CCC" BorderThickness="1"/>

                            <ComboBox x:Name="RatingCombo" Grid.Row="1" Grid.Column="0" Width="120" Margin="0,10,0,0" SelectedIndex="0">
                                <ComboBoxItem Content="⭐ 1"/>
                                <ComboBoxItem Content="⭐⭐ 2"/>
                                <ComboBoxItem Content="⭐⭐⭐ 3"/>
                                <ComboBoxItem Content="⭐⭐⭐⭐ 4"/>
                                <ComboBoxItem Content="⭐⭐⭐⭐⭐ 5"/>
                            </ComboBox>

                            <Button Content="✍ Отправить отзыв" Click="SendReview_Click" Grid.Row="1" Grid.Column="1" 
                                    Background="#3498DB" Foreground="White" BorderThickness="0"
                                    Padding="20,8" Cursor="Hand" FontSize="13" Margin="10,10,0,0"/>
                        </Grid>
                    </Border>

                    <Border Background="#F8F9FA" Padding="10">
                        <ListBox x:Name="ReviewsList" BorderThickness="0" Background="Transparent">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" Padding="12" Margin="0,0,0,8">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                <TextBlock Text="👤 " FontSize="12" Foreground="#7F8C8D"/>
                                                <TextBlock Text="{Binding User.DisplayName}" FontSize="12" FontWeight="SemiBold" Foreground="#2C3E50"/>
                                                <TextBlock Text=" · " FontSize="12" Foreground="#BDC3C7"/>
                                                <TextBlock Text="{Binding ReviewDate, StringFormat=\{0:dd.MM.yyyy\}}" FontSize="11" Foreground="#7F8C8D"/>
                                                <TextBlock Text=" · " FontSize="12" Foreground="#BDC3C7"/>
                                                <TextBlock Text="⭐ " FontSize="11" Foreground="#F1C40F"/>
                                                <TextBlock Text="{Binding Rating}" FontSize="11" Foreground="#7F8C8D"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ReviewText}" TextWrapping="Wrap" Foreground="#555" FontSize="13"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </StackPanel>
            </Border>

            <Button Grid.Row="5" Content="🚨 Пожаловаться на книгу" Click="Report_Click" 
                    HorizontalAlignment="Right" Margin="0,15,0,0"
                    Background="#E74C3C" Foreground="White" BorderThickness="0"
                    Padding="15,8" Cursor="Hand" FontSize="12"/>
        </Grid>
    </ScrollViewer>
</Page>