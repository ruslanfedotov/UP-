<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Читай, Пиши и не спиш" Height="600" Width="900" WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel>
                <Border Background="#1A252F" Padding="15,20">
                    <StackPanel>
                        <TextBlock Text="📖 Читай, Пиши" FontWeight="Bold" FontSize="13" Foreground="White" TextWrapping="Wrap" HorizontalAlignment="Center"/>
                        <TextBlock Text="не спиши" FontSize="11" Foreground="#BDC3C7" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="ОСНОВНОЕ" Foreground="#7F8C8D" FontSize="10" Margin="12,15,0,5" FontWeight="Bold"/>

                <Button x:Name="CatalogButton" Click="CatalogButton_Click" Margin="8,3" Padding="8,8" Cursor="Hand" Background="Transparent" BorderThickness="0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/katalog.png" Width="24" Height="24" Stretch="Uniform" Margin="0,0,10,0"/>
                        <TextBlock Text="Каталог книг" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="ListsButton" Click="ListsButton_Click" Margin="8,3" Padding="8,8" Cursor="Hand" Background="Transparent" BorderThickness="0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/SPIS.jpg" Width="24" Height="24" Stretch="Uniform" Margin="0,0,10,0"/>
                        <TextBlock Text="Мои списки" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="ProfileButton" Click="ProfileButton_Click" Margin="8,3" Padding="8,8" Cursor="Hand" Background="Transparent" BorderThickness="0">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/PROFILDINOSAVR.png" Width="24" Height="24" Stretch="Uniform" Margin="0,0,10,0"/>
                        <TextBlock Text="Профиль" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Border Height="1" Background="#3D566E" Margin="12,15,12,15"/>

                <TextBlock Text="УПРАВЛЕНИЕ" Foreground="#7F8C8D" FontSize="10" Margin="12,0,0,5" FontWeight="Bold"/>

                <Button x:Name="AuthorButton" Click="AuthorButton_Click" Margin="8,3" Padding="8,8" Cursor="Hand" Background="Transparent" BorderThickness="0" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/avtor.jpg" Width="24" Height="24" Stretch="Uniform" Margin="0,0,10,0"/>
                        <TextBlock Text="Страница автора" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="AdminButton" Click="AdminButton_Click" Margin="8,3" Padding="8,8" Cursor="Hand" Background="Transparent" BorderThickness="0" Visibility="Collapsed">
                    <StackPanel Orientation="Horizontal">
                        <Image Source="/admin.jpg" Width="24" Height="24" Stretch="Uniform" Margin="0,0,10,0"/>
                        <TextBlock Text="Администрирование" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="WarningButton" Margin="8,15" Padding="10,8" Cursor="Hand" Visibility="Collapsed" Background="#E74C3C" BorderThickness="0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="⚠️ " FontSize="16"/>
                        <TextBlock Text="АККАУНТ ЗАМОРОЖЕН!" FontSize="11" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="White" BorderBrush="#ECF0F1" BorderThickness="1,0,0,0">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>